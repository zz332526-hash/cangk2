page {
  /* 主题色 */
  --color-primary: #ff6678;
  --color-primary-weak: #ffe7ec;
  --color-accent: #8b5cf6;

  /* 语义色 */
  --color-success: #10b981;
  --color-warning: #f59e0b;

  /* 背景与内容色 */
  --color-bg: #f6f7fb;
  --color-surface: #ffffff;
  --color-border: #eceff4;

  /* 文字层级 */
  --color-text-1: #111827;
  --color-text-2: #374151;
  --color-text-3: #6b7280;
  --color-text-4: #9ca3af;

  /* 间距体系 */
  --space-1: 8rpx;
  --space-2: 12rpx;
  --space-3: 16rpx;
  --space-4: 24rpx;

  /* 圆角与阴影 */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 999rpx;
  --shadow-card: 0 4rpx 16rpx rgba(17, 24, 39, 0.08);

  /* 字号层级 */
  --font-page-title: 40rpx;
  --font-section-title: 34rpx;
  --font-body: 28rpx;
  --font-caption: 24rpx;

  /* 按钮规范 */
  --btn-height: 88rpx;
  --btn-radius: 16rpx;

  /* 暗色模式预留 token（暂不启用） */
  --dark-color-primary: #ff7a8a;
  --dark-color-bg: #0f172a;
  --dark-color-surface: #1e293b;
  --dark-color-text-1: #f3f4f6;
  --dark-color-text-2: #d1d5db;
  --dark-color-text-3: #9ca3af;

  background: var(--color-bg);
  color: var(--color-text-1);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: var(--font-body);
  line-height: 1.5;
}

/* 通用布局 */
.page-container {
  padding: var(--space-4);
}

/* 可复用卡片 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}

/* 标题与文本层级 */
.page-title {
  font-size: var(--font-page-title);
  font-weight: 700;
  color: var(--color-text-1);
}

.section-title {
  font-size: var(--font-section-title);
  font-weight: 700;
  color: var(--color-text-1);
}

.text-body {
  font-size: var(--font-body);
  color: var(--color-text-2);
}

.text-caption,
.sub-text {
  font-size: var(--font-caption);
  color: var(--color-text-3);
}

/* 按钮规范 */
.primary-btn {
  height: var(--btn-height);
  line-height: var(--btn-height);
  padding: 0 var(--space-4);
  border-radius: var(--btn-radius);
  border: none;
  background: linear-gradient(135deg, #ff7f7f, var(--color-primary));
  color: #ffffff;
  font-size: var(--font-body);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 120, 0.25);
}

/* 常用间距工具类 */
.mt-8 { margin-top: var(--space-1); }
.mt-12 { margin-top: var(--space-2); }
.mt-16 { margin-top: var(--space-3); }
.mt-24 { margin-top: var(--space-4); }

.p-8 { padding: var(--space-1); }
.p-12 { padding: var(--space-2); }
.p-16 { padding: var(--space-3); }
.p-24 { padding: var(--space-4); }
