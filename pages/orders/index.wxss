.container{ padding:20rpx; }
.tabs{ white-space:nowrap; margin-bottom:16rpx; }
.tab-item{ display:inline-block; padding:14rpx 24rpx; margin-right:14rpx; border-radius:999rpx; background:#f3f4f6; color:#4b5563; font-size:26rpx; }
.tab-item.active{ background:#111827; color:#fff; }
.order-card{ margin-bottom:16rpx; padding:24rpx; }
.row{ display:flex; justify-content:space-between; align-items:center; }
.header-row{ margin-bottom:12rpx; }
.amount-row{ margin-top:16rpx; }
.store-name{ font-size:30rpx; font-weight:700; }
.sub-text{ color:#6b7280; font-size:24rpx; }
.empty{ color:#9ca3af; text-align:center; margin-top:120rpx; }
