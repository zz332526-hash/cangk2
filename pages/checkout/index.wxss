.container{ padding:24rpx; }
.section{ padding:20rpx; margin-bottom:18rpx; }
.sec-title{ font-size:30rpx; font-weight:700; margin-bottom:14rpx; }
.tab-row{ display:flex; gap:12rpx; }
.tab{ flex:1; text-align:center; padding:16rpx 0; border-radius:14rpx; background:#f1f5f9; }
.tab.active{ background:#ffe4e6; color:#e11d48; font-weight:700; }
.line{ display:flex; justify-content:space-between; align-items:center; padding:14rpx 0; border-top:1rpx solid #f1f5f9; }
.form .line:first-child,.amount .line:first-child{ border-top:0; }
input{ text-align:right; color:#64748b; }
.qty-wrap{ display:flex; align-items:center; }
.qty-btn{ width:44rpx;height:44rpx;line-height:44rpx;text-align:center;border-radius:50%;background:#ffe4e6;color:#e11d48; }
.qty{ width:50rpx; text-align:center; }
.coupon{ color:#e11d48; }
.discount{ color:#10b981; }
.total{ font-weight:700; font-size:30rpx; }
.submit-btn{ margin-top:42rpx; background:#ff6678 !important; color:#fff !important; border-radius:999rpx; }
