.container { padding-bottom: 140rpx; }
.hero { width: 100%; height: 420rpx; }
.block { margin: 20rpx; padding: 20rpx; }
.name-row { display:flex; justify-content:space-between; align-items:center; }
.name { font-size: 36rpx; font-weight:600; }
.price { color:#ff4d4f; font-weight:700; }
.sub { color:#666; margin-top:10rpx; }
.tags { margin-top: 14rpx; display:flex; flex-wrap:wrap; gap: 12rpx; }
.tag { background:#f3f5f9; color:#666; border-radius: 999rpx; padding: 8rpx 16rpx; font-size:22rpx; }
.title { font-size: 30rpx; font-weight:600; margin-bottom: 14rpx; }
.detail-img { width:100%; border-radius: 12rpx; margin-bottom:12rpx; }
.review-row { display:flex; gap:20rpx; align-items: baseline; }
.score { font-size:34rpx; color:#fa8c16; font-weight:700; }
.bottom-bar { position: fixed; bottom: 0; left:0; right:0; background:#fff; border-top:1rpx solid #eee; padding: 16rpx 20rpx 24rpx; display:flex; gap:16rpx; }
.cart-btn { flex:1; border-radius:999rpx; background:#f5f5f5; }
.primary { flex:2; border-radius:999rpx; background:#ffcc32; }
