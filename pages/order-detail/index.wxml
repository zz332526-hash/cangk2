<view class="container" wx:if="{{order}}">
  <view class="card block">
    <view class="section-title">商品明细</view>
    <block wx:for="{{order.items}}" wx:key="id">
      <view class="row">
        <text>{{item.name}} x{{item.qty}}</text>
        <text>¥{{item.price * item.qty}}</text>
      </view>
    </block>
  </view>

  <view class="card block">
    <view class="section-title">费用明细</view>
    <view class="row"><text>商品小计</text><text>¥{{order.fees.goodsTotal}}</text></view>
    <view class="row"><text>打包费</text><text>¥{{order.fees.packFee}}</text></view>
    <view class="row"><text>配送费</text><text>¥{{order.fees.deliveryFee}}</text></view>
    <view class="row"><text>优惠</text><text>-¥{{order.fees.discount}}</text></view>
    <view class="row pay"><text>实付</text><text>¥{{order.fees.actualPay}}</text></view>
  </view>

  <view class="card block">
    <view class="section-title">配送信息</view>
    <view class="sub-text">{{order.delivery.receiver}}</view>
    <view class="sub-text">{{order.delivery.address}}</view>
  </view>

  <view class="card block">
    <view class="section-title">订单信息</view>
    <view class="sub-text">订单号：{{order.id}}</view>
    <view class="sub-text">下单时间：{{order.orderTime}}</view>
  </view>

  <view class="card block">
    <view class="section-title">订单时间线</view>
    <block wx:for="{{order.timeline}}" wx:key="time">
      <view class="timeline-item">
        <view>{{item.title}}</view>
        <view class="sub-text">{{item.time}}</view>
      </view>
    </block>
  </view>

  <button class="reorder-btn" bindtap="reorder">再来一单</button>
</view>
