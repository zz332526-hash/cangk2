.container { padding: 24rpx 24rpx 160rpx; }
.hero { display:flex; justify-content:space-between; align-items:center; padding: 28rpx; background: linear-gradient(140deg,#fff,#fff1f1); }
.store-title{ font-size: 38rpx; font-weight: 700; margin-bottom: 8rpx; }
.tag{ background: var(--brand-soft); color: var(--brand); font-size: 24rpx; padding: 10rpx 16rpx; border-radius: 999rpx; }
.section{ margin-top: 26rpx; }
.recommend-scroll{ white-space: nowrap; margin-top: 14rpx; }
.food-card{ display:inline-block; width: 280rpx; padding: 14rpx; margin-right: 16rpx; }
.food-img{ width:252rpx; height:170rpx; border-radius: 14rpx; }
.food-name{ font-size: 28rpx; font-weight: 600; margin-top: 8rpx; }
.price-row{ display:flex; justify-content:space-between; align-items:center; margin-top: 10rpx; }
.price{ color:#ef4444; font-weight:700; }
.add-btn{ margin:0; background:#ff6678 !important; color:#fff !important; border-radius:999rpx; min-width:72rpx; }
.menu{ padding: 18rpx; }
.menu-row{ display:flex; margin-top: 16rpx; }
.menu-img{ width:140rpx; height:140rpx; border-radius:14rpx; margin-right: 14rpx; }
.menu-info{ flex:1; }
.cart-bar{ position:fixed; left:24rpx; right:24rpx; bottom:28rpx; background:#111827; color:#fff; border-radius:24rpx; padding:18rpx 22rpx; display:flex; justify-content:space-between; align-items:center; }
.cart-title{ font-size: 30rpx; font-weight: 700; margin-bottom: 4rpx; }
