<view class="container">
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="skeleton-hero"></view>
    <view class="skeleton-grid"></view>
    <view class="skeleton-title"></view>
    <scroll-view scroll-x class="recommend-scroll">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </scroll-view>
    <view class="skeleton-cart"></view>
  </view>

  <block wx:else>
    <view class="hero-bg">
      <view class="hero card">
        <view>
          <view class="store-title">小满轻食茶饮</view>
          <view class="sub-text">营业中 · 距离 1.8km</view>
          <view class="delivery-text">蜂鸟专送 · 约 25 分钟送达 · 配送费 ¥3</view>
        </view>
        <view class="status-pill">营业中</view>
      </view>
    </view>

    <view class="section category card">
      <view class="section-title">分类</view>
      <view class="category-grid">
        <view class="category-item" wx:for="{{categoryList}}" wx:key="id">
          <view class="category-icon">{{item.icon}}</view>
          <view class="category-name">{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">热门推荐</view>
      <scroll-view scroll-x class="recommend-scroll" enable-flex="true">
        <view class="food-card card" wx:for="{{recommendList}}" wx:key="id">
          <image class="food-img" src="{{item.image}}" mode="aspectFill"/>
          <view class="food-name">{{item.name}}</view>
          <view class="sub-text">月售 {{item.sold}}</view>
          <view class="price-row">
            <text class="price">¥{{item.price}}</text>
            <button class="add-btn" size="mini" data-id="{{item.id}}" bindtap="addToCart">+</button>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="cart-bar {{cartCount > 0 ? 'cart-active' : 'cart-inactive'}}" bindtap="goOrders">
      <view class="cart-left">
        <view class="cart-title">已选 {{cartCount}} 件</view>
        <view class="sub-text">{{cartCount > 0 ? ('合计 ¥' + totalPrice) : '购物车还是空的，快去选购吧'}}</view>
      </view>
      <view class="checkout-btn {{cartCount > 0 ? 'checkout-active' : 'checkout-inactive'}}">去结算</view>
    </view>
  </block>
</view>
