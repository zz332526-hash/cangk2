.container { padding: 24rpx 24rpx 180rpx; }
.top-row{ display:flex; justify-content:space-between; align-items:center; margin-bottom:14rpx; }
.title{ font-size:34rpx; font-weight:700; }
.clear{ color:#ef4444; }
.group-card{ padding:18rpx; margin-top:16rpx; }
.group-name{ font-size:26rpx; font-weight:700; margin-bottom:10rpx; }
.item-row{ display:flex; align-items:center; padding:14rpx 0; border-top:1rpx solid #f1f5f9; }
.item-img{ width:100rpx; height:100rpx; border-radius:12rpx; margin-right:12rpx; }
.item-info{ flex:1; }
.item-name{ font-size:28rpx; }
.price-row{ display:flex; justify-content:space-between; align-items:center; margin-top:8rpx; }
.price{ color:#ef4444; font-weight:700; }
.qty-wrap{ display:flex; align-items:center; }
.qty-btn{ width:44rpx; height:44rpx; line-height:44rpx; text-align:center; border-radius:50%; background:#ffe4e6; color:#e11d48; }
.qty{ width:48rpx; text-align:center; }
.delete{ color:#94a3b8; font-size:24rpx; margin-left:10rpx; }
.bottom-bar{ position:fixed; left:24rpx; right:24rpx; bottom:24rpx; background:#111827; color:#fff; border-radius:24rpx; padding:18rpx; display:flex; justify-content:space-between; align-items:center; }
.checkout-btn{ margin:0; background:#ff6678 !important; color:#fff !important; border-radius:999rpx; }
.empty-wrap{ height:70vh; display:flex; flex-direction:column; align-items:center; justify-content:center; }
.empty-ill{ font-size:120rpx; }
.empty-title{ font-size:32rpx; font-weight:700; margin-top:12rpx; }
.empty-sub{ color:#94a3b8; margin-top:8rpx; }
.shop-btn{ margin-top:22rpx; background:#ff6678 !important; color:#fff !important; border-radius:999rpx; width:220rpx; }
