<view class="container">
  <block wx:if="{{cart.length}}">
    <view class="top-row">
      <text class="title">已选商品</text>
      <text class="clear" bindtap="clearCart">清空</text>
    </view>

    <block wx:for="{{groupCart}}" wx:key="groupName">
      <view class="card group-card">
        <view class="group-name">{{item.groupName}}</view>
        <block wx:for="{{item.items}}" wx:key="id">
          <view class="item-row">
            <image class="item-img" src="{{item.image}}" mode="aspectFill"/>
            <view class="item-info">
              <view class="item-name">{{item.name}}</view>
              <view class="price-row">
                <text class="price">¥{{item.price}}</text>
                <view class="qty-wrap">
                  <text class="qty-btn" data-id="{{item.id}}" data-step="-1" bindtap="changeQty">-</text>
                  <text class="qty">{{item.quantity}}</text>
                  <text class="qty-btn" data-id="{{item.id}}" data-step="1" bindtap="changeQty">+</text>
                </view>
              </view>
            </view>
            <text class="delete" data-id="{{item.id}}" bindtap="deleteItem">删除</text>
          </view>
        </block>
      </view>
    </block>

    <view class="bottom-bar">
      <view>
        <view class="sum">合计 ¥{{total}}</view>
      </view>
      <button class="checkout-btn" bindtap="goCheckout">去结算</button>
    </view>
  </block>

  <block wx:else>
    <view class="empty-wrap">
      <text class="empty-ill">🛒</text>
      <view class="empty-title">购物车空空如也</view>
      <view class="empty-sub">先去挑些好吃的吧</view>
      <button class="shop-btn" bindtap="goShop">去逛逛</button>
    </view>
  </block>
</view>
